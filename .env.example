# Optional GitHub integration.
# Atlas runs without these values. Keep real tokens in .env or .env.local only.
GITHUB_TOKEN=
GH_TOKEN=
GITHUB_REPOS=jmars319/JAMARQ-Atlas
GITHUB_OWNER=jmars319

# Optional Supabase hosted sync bridge.
# Atlas runs without these values. Use the service role key only on the local/server side.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ATLAS_SYNC_WORKSPACE_ID=

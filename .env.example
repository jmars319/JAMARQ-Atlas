# Optional GitHub integration.
# Atlas runs without these values. Keep real tokens in .env or .env.local only.
GITHUB_TOKEN=
GH_TOKEN=
GITHUB_REPOS=jmars319/JAMARQ-Atlas
GITHUB_OWNER=jmars319

# Optional Supabase hosted sync bridge.
# Atlas runs without these values. Use the service role key only on the local/server side.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ATLAS_SYNC_WORKSPACE_ID=

# Optional OpenAI draft-only Writing provider.
# Atlas runs without these values. Keep real API keys in .env or .env.local only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Optional read-only Dispatch host boundary.
# Keep credentials out of Atlas browser state. Use non-secret credentialRef labels only.
# Example:
# ATLAS_HOST_PREFLIGHT_CONFIG=[{"targetId":"midway-music-hall-production","credentialRef":"godaddy-mmh-production","host":"example.com","port":22,"localMirrorRoot":"/Volumes/read-only-sites/mmh"}]
ATLAS_HOST_PREFLIGHT_CONFIG=
